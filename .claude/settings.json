{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/observer-opt-out.py"],
            "timeout": 10,
            "statusMessage": "Observer Kit opt-out check"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/observer-gate.sh",
            "timeout": 30,
            "statusMessage": "Observer Kit side-effect gate"
          }
        ]
      }
    ]
  }
}
